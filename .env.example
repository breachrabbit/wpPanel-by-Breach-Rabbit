# =============================================================================
# wpPanel by Breach Rabbit — Environment Variables
# =============================================================================
# Скопируйте этот файл в .env и заполните значениями для вашего сервера
# cp .env.example .env
# 
# ⚠️ НИКОГДА не коммитьте .env в git! (добавлен в .gitignore)
# ⚠️ После заполнения установите права: chmod 600 .env
# =============================================================================

# -----------------------------------------------------------------------------
# 🔐 APP — Основные настройки приложения
# -----------------------------------------------------------------------------

# Режим работы (development | production)
NODE_ENV=production

# URL панели (без слэша в конце)
# Пример: https://panel.example.com или http://192.168.1.100:3000
NEXTAUTH_URL=https://panel.example.com

# Секрет для NextAuth.js (JWT signing)
# Генерация: openssl rand -base64 32
# Должен быть 32+ символа, уникальный для каждого сервера
NEXTAUTH_SECRET=your-super-secret-32-char-minimum-random-string-here

# Токен для первого запуска инсталлятора
# Генерация: openssl rand -hex 32
# ⚠️ УДАЛИТЕ эту переменную после завершения установки!
INSTALLER_TOKEN=your-one-time-setup-token-delete-after-install

# Порт для Next.js (в production через PM2/nginx)
PORT=3000

# Host для bind (0.0.0.0 для всех интерфейсов)
HOST=0.0.0.0

# -----------------------------------------------------------------------------
# 🗄️ DATABASE — PostgreSQL (для данных панели)
# -----------------------------------------------------------------------------

# Connection string для Prisma
# Формат: postgresql://user:password@host:port/database?schema=public
DATABASE_URL=postgresql://wppanel:your-secure-db-password@localhost:5432/wppanel?schema=public

# Отдельные компоненты (опционально, для гибкости)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wppanel
DB_USER=wppanel
DB_PASSWORD=your-secure-db-password

# Pool settings (опционально)
DB_POOL_MIN=2
DB_POOL_MAX=10

# -----------------------------------------------------------------------------
# 💾 REDIS — Кэш, сессии, очереди (BullMQ)
# -----------------------------------------------------------------------------

# Connection string для Redis
REDIS_URL=redis://localhost:6379

# Отдельные компоненты (опционально)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Префикс для ключей Redis (изоляция если несколько приложений)
REDIS_PREFIX=wppanel:

# TTL для сессий (секунды)
SESSION_TTL=604800

# -----------------------------------------------------------------------------
# 🌐 OPENLITESPEED — Web Server Integration
# -----------------------------------------------------------------------------

# URL OLS WebAdmin API (обычно порт 7080)
OLS_API_URL=http://localhost:7080

# Логин для OLS WebAdmin
OLS_API_USER=admin

# Пароль для OLS WebAdmin
OLS_API_PASS=your-ols-webadmin-password

# -----------------------------------------------------------------------------
# 📁 FILE SYSTEM — Пути на сервере
# -----------------------------------------------------------------------------

# Корневая директория для сайтов
SERVER_ROOT=/var/www

# Директория для бэкапов панели
BACKUP_ROOT=/var/backups/panel

# Директория для логов панели
LOG_ROOT=/var/log/wppanel

# Директория для временных файлов
TMP_ROOT=/tmp/wppanel

# -----------------------------------------------------------------------------
# 🔒 SSL — Certificates (acme.sh)
# -----------------------------------------------------------------------------

# Email для Let's Encrypt / ZeroSSL уведомлений
ACME_EMAIL=admin@example.com

# ACME CA (production | staging)
# Используйте staging для тестирования чтобы не исчерпать лимиты
ACME_CA=production

# -----------------------------------------------------------------------------
# 📧 SMTP — Email уведомления
# -----------------------------------------------------------------------------

# SMTP хост (например: smtp.gmail.com, smtp.mailgun.org)
SMTP_HOST=

# SMTP порт (587 TLS | 465 SSL | 25 plaintext)
SMTP_PORT=587

# SMTP пользователь (email адрес)
SMTP_USER=

# SMTP пароль (или app-password для Gmail)
SMTP_PASS=

# Email отправителя (From)
SMTP_FROM=wpPanel <noreply@example.com>

# Использовать TLS (true | false)
SMTP_SECURE=false

# -----------------------------------------------------------------------------
# 📱 TELEGRAM — Bot уведомления
# -----------------------------------------------------------------------------

# Токен бота (от @BotFather)
TELEGRAM_BOT_TOKEN=

# Chat ID для уведомлений (можно узнать через @userinfobot)
TELEGRAM_CHAT_ID=

# -----------------------------------------------------------------------------
# 🔐 SECURITY — Настройки безопасности
# -----------------------------------------------------------------------------

# Максимум попыток входа до блокировки
LOGIN_MAX_ATTEMPTS=5

# Время блокировки после превышения попыток (минуты)
LOGIN_BLOCK_DURATION=15

# Прогрессивная задержка между попытками (мс)
LOGIN_DELAY_BASE=1000

# Сессия 2FA backup кодов (сколько кодов генерировать)
2FA_BACKUP_CODES_COUNT=8

# Fail2ban integration (true | false)
FAIL2BAN_ENABLED=true

# -----------------------------------------------------------------------------
# 📊 MONITORING — Метрики и алерты
# -----------------------------------------------------------------------------

# Prometheus URL (если используется внешний)
PROMETHEUS_URL=http://localhost:9090

# Interval для сбора метрик (секунды)
METRICS_INTERVAL=30

# Пороги для алертов
ALERT_DISK_WARNING=80
ALERT_DISK_CRITICAL=90
ALERT_CPU_WARNING=80
ALERT_CPU_CRITICAL=95
ALERT_RAM_WARNING=80
ALERT_RAM_CRITICAL=95

# -----------------------------------------------------------------------------
# 💿 BACKUPS — Restic настройки
# -----------------------------------------------------------------------------

# Restic репозиторий (local | s3 | sftp | b2)
BACKUP_STORAGE_TYPE=local

# Local backup path (если BACKUP_STORAGE_TYPE=local)
BACKUP_LOCAL_PATH=/var/backups/panel/restic

# S3 настройки (если BACKUP_STORAGE_TYPE=s3)
BACKUP_S3_ENDPOINT=
BACKUP_S3_BUCKET=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_S3_REGION=us-east-1

# Restic пароль для шифрования бэкапов
# ⚠️ Потеря этого пароля = потеря всех бэкапов!
RESTIC_PASSWORD=your-super-secure-restic-password-here

# -----------------------------------------------------------------------------
# 🔄 AUTO UPDATE — Автообновление панели
# -----------------------------------------------------------------------------

# Включить проверку обновлений (true | false)
AUTO_UPDATE_CHECK=true

# Interval проверки (часы)
AUTO_UPDATE_CHECK_INTERVAL=24

# GitHub repo для проверки обновлений
GITHUB_REPO=breach-rabbit/wppanel

# -----------------------------------------------------------------------------
# 🌗 THEME — Настройки интерфейса
# -----------------------------------------------------------------------------

# Тема по умолчанию (dark | light | system)
DEFAULT_THEME=dark

# Язык по умолчанию (en | ru | es)
DEFAULT_LANGUAGE=en

# Часовой пояс
TIMEZONE=UTC

# -----------------------------------------------------------------------------
# 🧪 DEVELOPMENT — Только для dev режима
# -----------------------------------------------------------------------------

# Включить debug логи (true | false)
DEBUG=false

# Включить source maps в production (true | false)
# ⚠️ Не включайте в production — это раскрывает исходный код!
NEXT_PUBLIC_DEBUG=false

# Mock режим для сервисов (true | false)
# Используйте для разработки без реального сервера
MOCK_SERVICES=false

# -----------------------------------------------------------------------------
# 📈 ANALYTICS — Опционально
# -----------------------------------------------------------------------------

# Plausible Analytics (privacy-friendly)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Google Analytics (если очень нужно)
NEXT_PUBLIC_GA_ID=

# -----------------------------------------------------------------------------
# 🚀 PERFORMANCE — Оптимизация
# -----------------------------------------------------------------------------

# Количество воркеров для PM2
PM2_INSTANCES=1

# Max memory для PM2 (MB)
PM2_MAX_MEMORY=512

# Enable compression (true | false)
COMPRESSION_ENABLED=true

# Cache TTL для API ответов (секунды)
API_CACHE_TTL=60